<div class="header">
    <h1>Página Principal</h1>
    <img src="/img/mujer-lana2.png" alt="mujer-lana-2">
</div>
<hr>
<div class="enlaces">
    {{>menu}}
</div>


<hr>

<h2>Productos Cargados</h2>

<table>
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Code</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Category</th>
        </tr>
    </thead>

    <tbody id="productos-tbody">
        {{#each productos}}
        <tr>
            <td>{{title}}</td>
            <td>{{description}}</td>
            <td>{{code}}</td>
            <td>{{price}}</td>
            <td>{{stock}}</td>
            <td>{{category}}</td>
        </tr>
        {{/each}}
    </tbody>
</table>

<div class="card">
    <div class="figure">

    </div>
    <div class="info">
        <ul>
            <li>Title</li>
            <li>Description</li>
            <li>Code</li>
            <li>Price</li>
            <li>Stock</li>
            <li>Category</li>
        </ul>
    </div>
</div>

