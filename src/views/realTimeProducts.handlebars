<div class="header">
    <h1>Listado Productos</h1>
</div>

<hr>

<div class="enlaces">
    {{>menu}}
</div>
</div>

<hr>

<h2>Productos Actualizados</h2>

<table>
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Code</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Category</th>
        </tr>
    <tbody id="productos-tbody">
        {{#each productos}}
        <tr>
            <td>{{title}}</td>
            <td>{{description}}</td>
            <td>{{code}}</td>
            <td>{{price}}</td>
            <td>{{stock}}</td>
            <td>{{category}}</td>
        </tr>
        {{/each}}
    </tbody>
    </thead>


</table>


<div class="form-cont">

    <form method="post" action="/realTimeProducts" id="formulario">

        <label for="title">Title: </label>
        <input type="title" id="title" name="title" placeholder="Title" required>

        <label for="description">Description: </label>
        <input type="description" id="description" name="description" placeholder="Description" required>

        <label for="code">Code: </label>
        <input type="code" id="code" name="code" placeholder="Code" required>

        <label for="price">Price: </label>
        <input type="price" id="tipricetle" name="price" placeholder="Price" required>

        <label for="stock">Stock: </label>
        <input type="stock" id="stock" name="stock" placeholder="Stock" required>

        <label for="category">Category: </label>
        <input type="category" id="category" name="category" placeholder="Category" required>

        <button type="submit">Agregar Productos</button>

    </form>
    <img src="/img/mujer-lana1.png" alt="">
</div>





